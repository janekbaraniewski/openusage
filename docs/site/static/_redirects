# Cloudflare Pages redirects.
# The Docusaurus baseUrl is /docs/ — the standalone preview host (e.g.
# *.pages.dev) has nothing at the root, so we redirect to the docs index.

/                       /docs/                  302
/getting-started/*      /docs/getting-started/:splat  302
/concepts/*             /docs/concepts/:splat   302
/providers/*            /docs/providers/:splat  302
/daemon/*               /docs/daemon/:splat     302
/customization/*        /docs/customization/:splat  302
/reference/*            /docs/reference/:splat  302
/guides/*               /docs/guides/:splat     302
/troubleshooting/*      /docs/troubleshooting/:splat  302
/contributing/*         /docs/contributing/:splat  302
/faq                    /docs/faq/              302
